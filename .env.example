APP_ENV=development
APP_SECRET_KEY=replace-with-32-byte-random-value
DATABASE_URL=postgresql+psycopg://gate:gate@postgres:5432/gate
REDIS_URL=redis://redis:6379/0
STORAGE_ROOT=./storage
PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:3100,http://127.0.0.1:3100
HTTP_PORT=8092
API_BIND=127.0.0.1
API_PORT=8000
WEB_BIND=127.0.0.1
WEB_PORT=3000
HERMES_ENABLED=false
HERMES_MODE=http
HERMES_HTTP_URL=http://127.0.0.1:8787
OUTBOUND_PROXY_URL=
BUILD_HTTP_PROXY=
BUILD_HTTPS_PROXY=
BUILD_ALL_PROXY=
NO_PROXY=localhost,127.0.0.1,::1,postgres,redis,api,worker,web
GATE_CHALLENGER_HOST_PATH=/Users/iseremenko/Projects/Gate2-challenger
DEVILS_ADVOCATE_HOST_PATH=/Users/iseremenko/Documents/Common GPTs/devils-advocate
GATE_CHALLENGER_SOURCE_PATH=/external/gate-challenger
GATE2_BENCHMARK_DIR=/external/gate-challenger/benchmark
DEVILS_ADVOCATE_SOURCE_PATH=/external/devils-advocate
SKILL_SOURCE_SNAPSHOT_MODE=
POSTGRES_IMAGE=mirror.gcr.io/library/postgres:16-alpine
REDIS_IMAGE=mirror.gcr.io/library/redis:7-alpine
PYTHON_BASE_IMAGE=mirror.gcr.io/library/python:3.12-slim
NODE_BASE_IMAGE=mirror.gcr.io/library/node:22-alpine
